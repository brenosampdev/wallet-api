# ==========================================================================
# wallet-api — exemplo de variáveis de ambiente
# --------------------------------------------------------------------------
# Copie este arquivo para `.env` e ajuste os valores conforme o ambiente:
#     cp .env.example .env        (Linux/macOS)
#     Copy-Item .env.example .env (PowerShell)
#
# O `.env` real é ignorado pelo git (ver .gitignore). Nunca versione segredos.
#
# OBS.: o Spring Boot NÃO lê `.env` automaticamente. Use este arquivo para:
#   - o docker-compose (que pode carregar via `env_file`), e/ou
#   - exportar as variáveis na sua shell antes de rodar o app, ex.:
#       PowerShell:  Get-Content .env | ForEach-Object { if ($_ -match '^\s*([^#=]+)=(.*)$') { [Environment]::SetEnvironmentVariable($matches[1].Trim(), $matches[2].Trim()) } }
#       bash:        set -a; source .env; set +a
# Se a variável não for definida, o app usa o default indicado em comentário.
# ==========================================================================

# --- Banco de dados (PostgreSQL) ------------------------------------------
# Devem bater com o serviço `postgres` do docker-compose.yml.
DB_HOST=localhost          # default: localhost
DB_PORT=5432               # default: 5432
DB_NAME=wallet             # default: wallet
DB_USER=wallet             # default: wallet
DB_PASSWORD=wallet         # default: wallet  — TROQUE em produção

# --- Autenticação (JWT) ----------------------------------------------------
# Segredo HMAC do token. DEVE ter no mínimo 32 bytes. GERE um novo em produção.
# Ex. de geração: openssl rand -base64 48
JWT_SECRET=dev-secret-32bytes-min-CHANGE-IN-PROD-1234567890

# --- CORS ------------------------------------------------------------------
# Lista separada por vírgula das origens (frontends) permitidas.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
